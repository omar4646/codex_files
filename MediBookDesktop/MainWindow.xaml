<Window x:Class="MediBookDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediBook Desktop" Height="780" Width="1180" MinHeight="640" MinWidth="960"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0F4C69" Padding="18"
                Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="MediBook" FontSize="28" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock Text="Desktop" FontSize="16" Foreground="#C7DCE8" Margin="0,0,0,24" />
                    <TextBlock Text="{Binding UserDisplayName}" Foreground="#C7DCE8" Margin="0,0,0,18" TextWrapping="Wrap" />

                    <StackPanel Visibility="{Binding IsPatient, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button Content="Dashboard" Command="{Binding NavigatePatientDashboardCommand}" Style="{StaticResource NavButton}" />
                        <Button Content="Find doctors" Command="{Binding NavigateDoctorSearchCommand}" Style="{StaticResource NavButton}" />
                        <Button Content="My appointments" Command="{Binding NavigateMyAppointmentsCommand}" Style="{StaticResource NavButton}" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button Content="Dashboard" Command="{Binding NavigateAdminDashboardCommand}" Style="{StaticResource NavButton}" />
                        <Button Content="Doctors" Command="{Binding NavigateManageDoctorsCommand}" Style="{StaticResource NavButton}" />
                        <Button Content="Availability" Command="{Binding NavigateManageAvailabilityCommand}" Style="{StaticResource NavButton}" />
                        <Button Content="Appointments" Command="{Binding NavigateManageAppointmentsCommand}" Style="{StaticResource NavButton}" />
                        <Button Content="Specialties" Command="{Binding NavigateManageSpecialtiesCommand}" Style="{StaticResource NavButton}" />
                    </StackPanel>
                </StackPanel>

                <Button DockPanel.Dock="Bottom" Content="Logout" Command="{Binding LogoutCommand}" Style="{StaticResource NavButton}" />
            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" Margin="22"
                        Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibilityConverter}}">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="Grid.Column" Value="1" />
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <ContentControl Grid.ColumnSpan="2" Content="{Binding CurrentViewModel}">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAuthenticated}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>
    </Grid>
</Window>
