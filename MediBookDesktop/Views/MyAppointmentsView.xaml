<UserControl x:Class="MediBookDesktop.Views.MyAppointmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="My appointments" Style="{StaticResource TitleText}" />
            <StackPanel Orientation="Horizontal">
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" />
                <Button Content="Cancel selected" Command="{Binding CancelCommand}" Style="{StaticResource DangerButton}" />
            </StackPanel>
            <TextBlock Text="{Binding Message}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Appointments}" SelectedItem="{Binding SelectedAppointment}" Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding AppointmentCode}" Width="90" />
                <DataGridTextColumn Header="Doctor" Binding="{Binding Doctor.FullName}" Width="*" />
                <DataGridTextColumn Header="Specialty" Binding="{Binding Doctor.Specialty}" Width="140" />
                <DataGridTextColumn Header="Date/time" Binding="{Binding AppointmentDateTime, StringFormat='{}{0:MMM d, yyyy h:mm tt}'}" Width="190" />
                <DataGridTextColumn Header="Location" Binding="{Binding Doctor.Location}" Width="170" />
                <DataGridTextColumn Header="Reason" Binding="{Binding ReasonForVisit}" Width="220" />
                <DataGridTemplateColumn Header="Status" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Status, Converter={StaticResource StatusBrushConverter}}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="SemiBold" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Reschedule selected upcoming appointment" Style="{StaticResource SectionTitle}" />
                <ComboBox ItemsSource="{Binding RescheduleSlots}" SelectedItem="{Binding SelectedNewSlot}" DisplayMemberPath="DisplayTime" />
                <Button Content="Reschedule" Command="{Binding RescheduleCommand}" HorizontalAlignment="Left" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
