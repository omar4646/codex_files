<UserControl x:Class="MediBookDesktop.Views.ManageDoctorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,14,0">
            <TextBlock Text="Manage doctors" Style="{StaticResource TitleText}" />
            <StackPanel Orientation="Horizontal">
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" />
                <Button Content="New doctor" Command="{Binding NewDoctorCommand}" />
                <Button Content="Delete selected" Command="{Binding DeleteDoctorCommand}" Style="{StaticResource DangerButton}" />
            </StackPanel>
            <TextBlock Text="{Binding Message}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
            <DataGrid ItemsSource="{Binding Doctors}" SelectedItem="{Binding SelectedDoctor}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*" />
                    <DataGridTextColumn Header="Specialty" Binding="{Binding Specialty}" Width="140" />
                    <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="170" />
                    <DataGridTextColumn Header="Fee" Binding="{Binding ConsultationFee, StringFormat='{}{0:C}'}" Width="90" />
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70" />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <Border Grid.Column="1" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Doctor form" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="Full name" FontWeight="SemiBold" />
                    <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Specialty" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding Specialties}" Text="{Binding Specialty, UpdateSourceTrigger=PropertyChanged}" IsEditable="True" />
                    <TextBlock Text="Clinic location" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Consultation fee" FontWeight="SemiBold" />
                    <TextBox Text="{Binding ConsultationFee, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Bio" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Bio, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="120" TextWrapping="Wrap" />
                    <CheckBox Content="Active" IsChecked="{Binding IsActive}" Margin="0,6,0,12" />
                    <Button Content="Save doctor" Command="{Binding SaveDoctorCommand}" HorizontalAlignment="Stretch" Margin="0,4,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
