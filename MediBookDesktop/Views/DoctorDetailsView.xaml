<UserControl x:Class="MediBookDesktop.Views.DoctorDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Doctor profile" Style="{StaticResource TitleText}" />
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{Binding Doctor.FullName}" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Doctor.Specialty}" Foreground="{StaticResource AccentDarkBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding Doctor.Location}" Style="{StaticResource MutedText}" />
                    <TextBlock Text="{Binding Doctor.ConsultationFee, StringFormat='Consultation fee: {0:C}'}" FontWeight="SemiBold" Margin="0,10,0,0" />
                    <TextBlock Text="{Binding Doctor.Bio}" TextWrapping="Wrap" Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,12">
                    <StackPanel>
                        <TextBlock Text="Available appointment slots" Style="{StaticResource SectionTitle}" />
                        <DatePicker SelectedDate="{Binding SelectedDate}" Width="180" HorizontalAlignment="Left" />
                        <DataGrid ItemsSource="{Binding AvailableSlots}" SelectedItem="{Binding SelectedSlot}" Height="320">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding StartTime, StringFormat='{}{0:MMM d, yyyy}'}" Width="150" />
                                <DataGridTextColumn Header="Time" Binding="{Binding ShortTime}" Width="160" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Book appointment" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Reason for visit" FontWeight="SemiBold" />
                        <TextBox Text="{Binding ReasonForVisit, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="110" TextWrapping="Wrap" />
                        <Button Content="Confirm booking" Command="{Binding BookCommand}" HorizontalAlignment="Stretch" Margin="0,8,0,4" />
                        <TextBlock Text="{Binding Message}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" Margin="0,10,0,0" />
                        <TextBlock Text="{Binding ConfirmationText}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,12,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
