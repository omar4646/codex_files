<UserControl x:Class="MediBookDesktop.Views.DoctorSearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Find a doctor" Style="{StaticResource TitleText}" />
            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Doctor name" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Specialty" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding SpecialtyOptions}" SelectedItem="{Binding SelectedSpecialty}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="Location" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding LocationOptions}" SelectedItem="{Binding SelectedLocation}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,12,0">
                        <TextBlock Text="Available date" FontWeight="SemiBold" />
                        <DatePicker SelectedDate="{Binding AvailableDate}" />
                    </StackPanel>
                    <Button Grid.Column="4" Content="Search" Command="{Binding SearchCommand}" VerticalAlignment="Center" />
                </Grid>
            </Border>
            <TextBlock Text="{Binding Message}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
        </StackPanel>

        <ListBox Grid.Row="1" ItemsSource="{Binding Doctors}" SelectedItem="{Binding SelectedDoctor}" BorderThickness="0" Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource Card}" Width="820">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding FullName}" FontSize="19" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Specialty}" Foreground="{StaticResource AccentDarkBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding Location}" Style="{StaticResource MutedText}" />
                                <TextBlock Text="{Binding Bio}" TextWrapping="Wrap" Margin="0,8,20,0" />
                                <TextBlock Text="{Binding ConsultationFee, StringFormat='Consultation fee: {0:C}'}" FontWeight="SemiBold" Margin="0,8,0,0" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="View slots"
                                    Command="{Binding DataContext.OpenDoctorCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
