<UserControl x:Class="MediBookDesktop.Views.ManageAppointmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Manage appointments" Style="{StaticResource TitleText}" />
            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Doctor" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding Doctors}" SelectedItem="{Binding SelectedDoctorFilter}" DisplayMemberPath="FullName" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Patient name or email" FontWeight="SemiBold" />
                        <TextBox Text="{Binding PatientFilter, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="Date" FontWeight="SemiBold" />
                        <DatePicker SelectedDate="{Binding SelectedDate}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,12,0">
                        <TextBlock Text="Status" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding StatusFilter}" />
                    </StackPanel>
                    <Button Grid.Column="4" Content="Filter" Command="{Binding RefreshCommand}" VerticalAlignment="Center" />
                </Grid>
            </Border>
            <TextBlock Text="{Binding Message}" Style="{StaticResource MutedText}" Margin="0,0,0,8" />
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Appointments}" SelectedItem="{Binding SelectedAppointment}" Margin="0,0,0,12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding AppointmentCode}" Width="90" />
                <DataGridTextColumn Header="Patient" Binding="{Binding Patient.FullName}" Width="150" />
                <DataGridTextColumn Header="Email" Binding="{Binding Patient.Email}" Width="190" />
                <DataGridTextColumn Header="Doctor" Binding="{Binding Doctor.FullName}" Width="160" />
                <DataGridTextColumn Header="Date/time" Binding="{Binding AppointmentDateTime, StringFormat='{}{0:MMM d, yyyy h:mm tt}'}" Width="190" />
                <DataGridTextColumn Header="Reason" Binding="{Binding ReasonForVisit}" Width="*" />
                <DataGridTemplateColumn Header="Status" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Status, Converter={StaticResource StatusBrushConverter}}" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="SemiBold" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Update selected appointment to" VerticalAlignment="Center" Margin="0,0,12,0" FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding StatusUpdateOptions}" SelectedItem="{Binding NewStatus}" Width="150" />
                <Button Content="Save status" Command="{Binding UpdateStatusCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
