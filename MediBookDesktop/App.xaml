<Application x:Class="MediBookDesktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:MediBookDesktop.Helpers"
             xmlns:views="clr-namespace:MediBookDesktop.Views"
             xmlns:vm="clr-namespace:MediBookDesktop.ViewModels">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:AppointmentStatusBrushConverter x:Key="StatusBrushConverter" />

        <Color x:Key="InkColor">#172033</Color>
        <Color x:Key="MutedColor">#667085</Color>
        <Color x:Key="AccentColor">#146C94</Color>
        <Color x:Key="AccentDarkColor">#0F4C69</Color>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F7FB" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}" />
        <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8E1EA" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="WarningBrush" Color="#A16207" />
        <SolidColorBrush x:Key="DangerBrush" Color="#B42318" />

        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="Padding" Value="8,5" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="0,4,0,10" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,4,8,4" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
        </Style>

        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#EAF2F8" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>

        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RegisterViewModel}">
            <views:RegisterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PatientDashboardViewModel}">
            <views:PatientDashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DoctorSearchViewModel}">
            <views:DoctorSearchView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DoctorDetailsViewModel}">
            <views:DoctorDetailsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MyAppointmentsViewModel}">
            <views:MyAppointmentsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AdminDashboardViewModel}">
            <views:AdminDashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ManageDoctorsViewModel}">
            <views:ManageDoctorsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ManageAvailabilityViewModel}">
            <views:ManageAvailabilityView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ManageAppointmentsViewModel}">
            <views:ManageAppointmentsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ManageSpecialtiesViewModel}">
            <views:ManageSpecialtiesView />
        </DataTemplate>
    </Application.Resources>
</Application>
